{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "declarationDir": "dist/types",
    "outDir": "dist/cjs",
    "rootDir": "./src",
    "module": "CommonJS",
    "moduleResolution": "node",
    "target": "es2015",
    "downlevelIteration": true,
    "tsBuildInfoFile": "./.tsbuildinfo.cjs"
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["src/__tests__/**", "src/**/*.test.ts", "src/**/*.test.tsx"]
}
