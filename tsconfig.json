{
  "extends": ["expo/tsconfig.base", "./tsconfig.base.json"],
  "compilerOptions": {
    "declarationDir": "dist/types",
    "outDir": "dist",
    "rootDir": "./src",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "tsBuildInfoFile": ".tsbuildinfo"
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts"],
  "exclude": ["dist/**", "coverage/**", "__mocks__/**", "test-install/**", "node_modules/**"]
}
