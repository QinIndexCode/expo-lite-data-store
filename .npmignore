# Source code (only distribute compiled output)
src/

# Test files
__tests__/
__mocks__/
apiTest/
coverage/
*.test.ts
*.test.js
*.spec.ts
*.spec.js
test-scripts/

# Build and config files
jest*.cjs
jest*.config.cjs
eslint.config.js
eslint*.js
prettier*.js
.prettierrc*
*.tsbuildinfo

# TypeScript config (only types config needed for consumers)
tsconfig.cjs.json
tsconfig.base.json

# Dev and env config files
package-dev.json
package-env.json
package-lock.json

# Expo / React Native dev files
.expo/
.expo-shared/
app.json
metro.config.js
babel.config.js
expo-env.d.ts

# Documentation (keep only README.md and LICENSE)
*.md
!README.md
!LICENSE.txt
docs/

# Tools and temp files
code-improvement-report.js
debug-*.*
test-*.*
*.tgz
*.tmp
*.log

# IDE config
.vscode/
.trae/
.idea/
*.swp
*.swo

# Git files
.git/
.gitignore

# Test config
jest.*
