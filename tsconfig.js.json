{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "declarationDir": "dist/types",
    "outDir": "dist/js",
    "rootDir": "./src",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "es2015",
    "downlevelIteration": true,
    "tsBuildInfoFile": "./.tsbuildinfo.esm"
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["src/__tests__/**", "src/**/*.test.ts", "src/**/*.test.tsx"]
}
