{
  "name": "expo-lite-data-store",
  "version": "3.0.0",
  "main": "dist/cjs/index.js",
  "types": "dist/types/index.d.ts",
  "author": "QinIndexCode",
  "license": "MIT",
  "description": "Local structured storage for Expo applications with runtime-tested Expo Go and native support.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/QinIndexCode/expo-lite-data-store.git"
  },
  "homepage": "https://github.com/QinIndexCode/expo-lite-data-store#readme",
  "bugs": {
    "url": "https://github.com/QinIndexCode/expo-lite-data-store/issues"
  },
  "keywords": [
    "expo",
    "data store",
    "lite",
    "data",
    "storage",
    "react-native"
  ],
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/js/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./js": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/js/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./cjs": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/cjs/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./utils/*": {
      "types": "./dist/types/utils/*.d.ts",
      "import": "./dist/js/utils/*.js",
      "require": "./dist/cjs/utils/*.js"
    }
  },
  "files": [
    "dist",
    "docs",
    "README.md",
    "README.en.md",
    "README.zh-CN.md",
    "LICENSE.txt"
  ],
  "scripts": {
    "build": "npm run build:all",
    "build:js": "tsc -p tsconfig.js.json",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build:types": "tsc -p tsconfig.types.json",
    "build:all": "rimraf dist && npm run build:js && npm run write:esm-package && npm run patch:esm-extensions && npm run build:cjs && npm run build:types && rimraf .tsbuildinfo .tsbuildinfo.esm .tsbuildinfo.cjs && npm run lint",
    "clean": "rimraf dist coverage artifacts .tsbuildinfo .tsbuildinfo.esm .tsbuildinfo.cjs",
    "clean:artifacts": "rimraf artifacts",
    "test": "jest --config jest.simple.config.cjs --testPathIgnorePatterns=crypto-security-assessment --testPathIgnorePatterns=performance-optimization --testPathIgnorePatterns=api.stress --testPathIgnorePatterns=benchmark",
    "test:core": "jest --config jest.simple.config.cjs --testPathIgnorePatterns=crypto-security-assessment --testPathIgnorePatterns=performance-optimization --testMatch=**/src/core/**/__tests__/**/*.test.ts",
    "test:api": "jest --config jest.simple.config.cjs --testPathPatterns=api --testPathIgnorePatterns=api.stress",
    "test:stress": "jest --config jest.simple.config.cjs --testMatch=**/api.stress.test.ts",
    "test:utils": "jest --config jest.simple.config.cjs --testMatch=**/src/utils/**/__tests__/**/*.test.ts",
    "test:crypto": "jest --config jest.crypto.config.cjs",
    "test:performance": "jest --config jest.performance.config.cjs",
    "test:all": "npm run test && npm run test:stress && npm run test:crypto && npm run test:performance",
    "test:watch": "jest --config jest.simple.config.cjs --watch --testPathIgnorePatterns=crypto-security-assessment --testPathIgnorePatterns=performance-optimization --testPathIgnorePatterns=api.stress --testPathIgnorePatterns=benchmark",
    "test:coverage": "jest --config jest.simple.config.cjs --coverage --testPathIgnorePatterns=crypto-security-assessment,performance-optimization",
    "test:coverage:unit": "jest --config jest.simple.config.cjs --coverage --testPathIgnorePatterns=crypto-security-assessment,performance-optimization --testPathPatterns=src/__tests__/unit/",
    "test:cache": "jest --config jest.simple.config.cjs --testMatch=**/src/core/cache/__tests__/**/*.test.ts",
    "lint": "eslint . --ext .ts,.tsx --ignore-pattern '.tsbuildinfo*'",
    "lint:fix": "eslint . --ext .ts,.tsx --fix --ignore-pattern '.tsbuildinfo*'",
    "format": "prettier --write --ignore-unknown --ignore-path .prettierignore .",
    "format:check": "prettier --check --ignore-unknown --ignore-path .prettierignore .",
    "audit:prod": "npm audit --omit=dev",
    "audit:no-high": "npm audit --audit-level=high",
    "typecheck": "tsc --noEmit --incremental false && tsc -p tsconfig.mocks.json --incremental false",
    "patch:esm-extensions": "node ./scripts/patch-esm-extensions.cjs",
    "write:esm-package": "node ./scripts/write-esm-package.cjs",
    "smoke:expo-consumer": "node ./scripts/smoke-expo-consumer.cjs",
    "qa:expo-go:contract": "node ./scripts/expo-runtime-qa.cjs --layers=contract",
    "qa:expo-go": "node ./scripts/expo-runtime-qa.cjs --layers=contract,runtime",
    "qa:expo-go:full": "node ./scripts/expo-runtime-qa.cjs --layers=contract,runtime,soak --soak-minutes=30",
    "qa:expo-go:mumu": "node ./scripts/mumu-expo-qa.cjs run-qa --repo . --layers contract,runtime --channels single-package,managed-compatible --cleanup-consumers",
    "qa:expo-go:mumu:full": "node ./scripts/mumu-expo-qa.cjs run-qa --repo . --layers contract,runtime,soak --channels single-package,managed-compatible --soak-minutes 30 --cleanup-consumers",
    "qa:flagship:native": "node ./scripts/mumu-expo-qa.cjs run-qa --repo . --layers contract,runtime --channels managed-compatible --cleanup-consumers --extra-arg=--profiles=native-quick-crypto",
    "qa:baseline:expo-go": "npm run qa:expo-go:mumu",
    "qa:baseline:native-flagship": "npm run qa:flagship:native",
    "qa:baseline:release": "npm run qa:baseline:expo-go && npm run qa:baseline:native-flagship",
    "prepare": "npm run build",
    "prepublishOnly": "npm run format:check && npm run audit:prod && npm run audit:no-high && npm run typecheck && npm run build:all && npm run test:all && npm run smoke:expo-consumer"
  },
  "dependencies": {
    "@noble/ciphers": "~0.6.0",
    "bcryptjs": "~2.4.3",
    "crypto-js": "^4.2.0"
  },
  "peerDependencies": {
    "expo": ">=56 <57",
    "expo-constants": "~56.0.18",
    "expo-crypto": "~56.0.4",
    "expo-file-system": "~56.0.8",
    "expo-secure-store": "~56.0.4",
    "react": ">=19.2.0 <20",
    "react-native": ">=0.85.0 <0.86",
    "react-native-quick-crypto": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "expo": {
      "optional": false
    },
    "expo-constants": {
      "optional": false
    },
    "expo-crypto": {
      "optional": false
    },
    "expo-file-system": {
      "optional": false
    },
    "expo-secure-store": {
      "optional": false
    },
    "react": {
      "optional": false
    },
    "react-native": {
      "optional": false
    },
    "react-native-quick-crypto": {
      "optional": true
    }
  },
  "overrides": {
    "js-yaml": "4.2.0",
    "xcode": {
      "uuid": "11.1.1"
    }
  },
  "devDependencies": {
    "@babel/plugin-transform-modules-commonjs": "^7.29.7",
    "@eslint/js": "^9.39.4",
    "@types/bcryptjs": "^2.4.6",
    "@types/crypto-js": "^4.2.2",
    "@types/jest": "^29.5.0",
    "@types/node": "^24.13.2",
    "@types/react": "~19.2.14",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "babel-preset-expo": "~56.0.15",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "expo": "~56.0.12",
    "expo-constants": "~56.0.18",
    "expo-crypto": "~56.0.4",
    "expo-file-system": "~56.0.8",
    "expo-secure-store": "~56.0.4",
    "globals": "^17.6.0",
    "jest": "^29.7.0",
    "jiti": "^2.7.0",
    "prettier": "^3.8.4",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.4.11",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.61.0"
  },
  "private": false
}
