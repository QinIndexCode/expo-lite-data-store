{
  "name": "expo-lite-data-store",
  "version": "2.0.0-beta.5",
  "main": "dist/cjs/index.js",
  "types": "dist/types/index.d.ts",
  "author": "QinIndexCode",
  "license": "MIT",
  "description": "A lite data store for Expo; Detail in https://github.com/QinIndexCode/expo-lite-data-store. **Note:** All scripts in this package.json are for development purposes only and may not work in production environments.",
  "versionDescription": "Major release with enhanced encryption, improved field-level encryption logic, and various performance optimizations.",
  "keywords": [
    "expo",
    "data store",
    "lite",
    "data",
    "storage",
    "react-native"
  ],
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/js/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./js": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/js/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./cjs": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/cjs/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./dist/js/*": {
      "import": "./dist/js/*",
      "require": "./dist/cjs/*"
    },
    "./dist/cjs/*": {
      "import": "./dist/cjs/*",
      "require": "./dist/cjs/*"
    },
    "./utils/*": {
      "import": "./dist/js/utils/*",
      "require": "./dist/cjs/utils/*"
    }
  },
  "scripts": {
    "build": "npm run build:all",
    "build:js": "tsc -p tsconfig.js.json",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build:types": "tsc -p tsconfig.types.json",
    "build:all": "rimraf dist && npm run build:js && npm run build:cjs && npm run build:types && rimraf .tsbuildinfo .tsbuildinfo.esm .tsbuildinfo.cjs && npm run lint",
    "clean": "rimraf dist",
    "test": "jest --config jest.simple.config.cjs --testPathIgnorePatterns=crypto-security-assessment --testPathIgnorePatterns=performance-optimization --testPathIgnorePatterns=api.stress",
    "test:core": "jest --config jest.simple.config.cjs --testPathIgnorePatterns=crypto-security-assessment --testPathIgnorePatterns=performance-optimization --testMatch=**/src/core/**/__tests__/**/*.test.ts",
    "test:api": "jest --config jest.simple.config.cjs --testPathPatterns=api --testPathIgnorePatterns=api.stress",
    "test:stress": "jest --config jest.simple.config.cjs --testMatch=**/api.stress.test.ts",
    "test:utils": "jest --config jest.simple.config.cjs --testMatch=**/src/utils/**/__tests__/**/*.test.ts",
    "test:simple": "jest --config jest.simple.config.cjs --testMatch=**/src/__tests__/unit/simple.test.ts",
    "test:crypto": "jest --config jest.crypto.config.cjs",
    "test:performance": "jest --config jest.performance.config.cjs --passWithNoTests",
    "test:all": "npm run test:core && npm run test:api && npm run test:utils && npm run test:simple && npm run test:crypto && npm run test:performance",
    "test:watch": "jest --config jest.simple.config.cjs --watch --testPathIgnorePatterns=crypto-security-assessment --testPathIgnorePatterns=performance-optimization",
    "test:coverage": "jest --config jest.simple.config.cjs --coverage --testPathIgnorePatterns=crypto-security-assessment,performance-optimization",
    "test:coverage:unit": "jest --config jest.simple.config.cjs --coverage --testPathIgnorePatterns=crypto-security-assessment,performance-optimization --testPathPatterns=src/__tests__/unit/",
    "test:cache": "jest --config jest.simple.config.cjs --testMatch=**/src/core/cache/__tests__/**/*.test.ts",
    "lint": "eslint . --ext .ts,.tsx --ignore-pattern '.tsbuildinfo*'",
    "lint:fix": "eslint . --ext .ts,.tsx --fix --ignore-pattern '.tsbuildinfo*'",
    "format": "prettier --write . --ignore-path .prettierignore",
    "format:check": "prettier --check . --ignore-path .prettierignore",
    "typecheck": "tsc --noEmit",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build:all && npm run typecheck",
    "publish:safe": "npm run build && npm run typecheck && npm publish",
    "publish:force": "npm publish --ignore-scripts"
  },
  "dependencies": {
    "@noble/ciphers": "~0.6.0",
    "@noble/hashes": "~1.8.0",
    "bcryptjs": "~2.4.3",
    "expo-constants": "~18.0.12",
    "expo-crypto": "~15.0.8",
    "expo-file-system": "~18.1.11",
    "expo-secure-store": "~15.0.8"
  },
  "peerDependencies": {
    "expo": ">=50.0.0",
    "react": ">=18.0.0",
    "react-native": ">=0.73.0",
    "react-native-quick-crypto": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "expo": {
      "optional": false
    },
    "react": {
      "optional": false
    },
    "react-native": {
      "optional": false
    },
    "react-native-quick-crypto": {
      "optional": true
    }
  },
  "private": false
}
